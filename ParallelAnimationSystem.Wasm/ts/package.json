{
  "name": "paswasm",
  "version": "0.0.5",
  "description": "Typed JavaScript package for ParallelAnimationSystem.Wasm",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build:js": "tsup src/**/*.ts --format esm --dts --splitting --out-dir dist",
    "build:wasm": "copyfiles -f src/wasm/ParallelAnimationSystem.Wasm.wasm dist/",
    "build": "pnpm run build:js && pnpm run build:wasm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reimnop/ParallelAnimationSystem.git"
  },
  "author": "Reimnop",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/Reimnop/ParallelAnimationSystem/issues"
  },
  "homepage": "https://github.com/Reimnop/ParallelAnimationSystem#readme",
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
