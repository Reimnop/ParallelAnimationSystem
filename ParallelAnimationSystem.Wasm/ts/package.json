{
  "name": "paswasm",
  "version": "0.0.1",
  "description": "Typed JavaScript package for ParallelAnimationSystem.Wasm",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build:js": "esbuild src/index.ts --bundle --minify --format=esm --platform=browser --loader:.wasm=file --outfile=dist/index.js",
    "build:types": "tsc",
    "build:wasm": "copyfiles -f src/wasm/ParallelAnimationSystem.Wasm.wasm dist/",
    "build": "pnpm run build:js && pnpm run build:types && pnpm run build:wasm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reimnop/ParallelAnimationSystem.git"
  },
  "author": "Reimnop",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/Reimnop/ParallelAnimationSystem/issues"
  },
  "homepage": "https://github.com/Reimnop/ParallelAnimationSystem#readme",
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
